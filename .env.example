# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=          # Server-only — never expose to client

# Email (Resend)
RESEND_API_KEY=

# Mapbox (for alumni world map)
NEXT_PUBLIC_MAPBOX_TOKEN=

# Google OAuth (configure in Supabase dashboard for production)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# App
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Events — HMAC secret for signed .ics links (required for unauthenticated calendar fetches)
ICS_SIGNING_SECRET=
